% \maketitle
%
% \begin{abstract}
%   The \textsf{conversationalcomments} package provides a \LaTeX\ interface for margin comments linked to highlighted document text. It supports commentator registration, alternating threads, and multi-author conversation blocks.
% \end{abstract}
%
% \section{Introduction}
% This package implements a margin comment environment for \LaTeX. Commentators registered in the preamble generate macros for text highlighting and margin notes with connecting lines. Features include alternating threads and multi-author conversation blocks.
%
% \section{Usage Guide}
%
% \subsection{Preamble Setup}
% Simply load the package in your preamble:
% \begin{verbatim}
%   \usepackage{conversationalcomments}
% \end{verbatim}
%
% The package supports the following options:
% \begin{itemize}
%   \item \texttt{draft} (default): Enables comments, highlights, and geometry adjustments.
%   \item \texttt{final}: Disables all comments and highlights, restoring the original document geometry.
% \end{itemize}
%
% \DescribeMacro{\setreviewmarginwidth}
% To customize the width of the review margins, use \cs{setreviewmarginwidth}\marg{width}.
% For example, a wider margin accommodates longer comment text:
% \begin{verbatim}
%   \setreviewmarginwidth{1.5in}
% \end{verbatim}
%
% \subsection{Registering Commentators}
%
% \DescribeMacro{\newcommentator}
% The package does not define hardcoded commentators. Instead, you declare your review team in the preamble using:
% \cs{newcommentator}\marg{cmd\_name}\marg{Label}\marg{Color}\oarg{Default Partner}
%
% For example:
% \begin{verbatim}
%   \newcommentator{bill}{Bill}{pastelblue}[vale]
%   \newcommentator{vale}{Vale}{pastelred}[bill]
%   \newcommentator{alice}{Alice}{pastelgreen}
% \end{verbatim}
%
% This generates author macros like \cs{bill}, \cs{vale}, and \cs{alice}, as well as their corresponding inline formatters (such as \cs{billreply}, which are invoked automatically).
%
% \subsection{Comment Modes}
%
% \subsubsection{Text-Linked Comments (Highlights)}
% Use the commentator's command with two arguments. The first argument specifies the document text to highlight, and the second is your comment:
% \begin{verbatim}
%   \bill{highlighted text}{This text is blue, and this is my comment.}
% \end{verbatim}
% Here is a live example: \bill{this is a live text-linked comment}{This comment is rendered in the margin with a connecting line back to this text.}
%
% \subsubsection{Standalone Notes}
% To place a floating note in the margin without highlighting any body text, leave the first argument empty:
% \begin{verbatim}
%   \vale{}{This is a floating note next to this line.}
% \end{verbatim}
% \vale{}{This is a live standalone note next to this paragraph.}
%
% \subsubsection{Conversational Threads (Alternating)}
% Provide consecutive arguments to alternate replies between the commentator and their registered default partner:
% \begin{verbatim}
%   \bill{The system dynamics}{Initial query}{First response}{Second response}
% \end{verbatim}
% Here is an alternating thread example: \bill{Live conversation}{Is this compiled from the source file?}{Yes, the documentation is compiled directly from the .dtx source.}{The output is displayed in the margin.}
%
% \subsubsection{Third-Party Nesting}
% A third reviewer can join a two-author thread by nesting their command inside a reply argument:
% \begin{verbatim}
%   \bill{Reference Text}{Initial comment.}{\vale{Reviewer response.}}{\alice{Additional comment.}}
% \end{verbatim}
% Here is an example of nesting: \bill{Nesting example}{Initial query.}{\vale{First response.}}{\alice{Second response.}}
%
% \subsection{Multi-Author Conversations}
%
% \DescribeMacro{\conversation}
% For discussions involving three or more people, use the \cs{conversation}\marg{Target Text}\marg{Body} environment. Inside this environment, commentator commands act as inline reply formatters:
% \begin{verbatim}
%   \conversation{Target Text}{
%     \bill{Proposed revision for this section.}
%     \vale{The modification matches the technical requirements.}
%     \alice{The comments are aligned with the text.}
%   }
% \end{verbatim}
% Here is an example of a multi-author conversation:
% \conversation{Multi-author demo}{
%   \bill{Proposed revision for this section.}
%   \vale{The modification matches the technical requirements.}
%   \alice{The comments are aligned with the text.}
% }
%
% \subsection{Conversation Resolution and Reporting}
% All commentator macros and the \cs{conversation} environment support a starred variant (e.g., \cs{bill*}, \cs{conversation*}) to mark a conversation as resolved. Resolved comments are labeled with a \texttt{[Resolved]} prefix in the margin.
%
% \DescribeMacro{\printconversations}
% Use the \cs{printconversations} macro to generate a hyperlinked summary report of all conversations in the document:
% \begin{verbatim}
%   \printconversations[filter]
% \end{verbatim}
% Supported filter arguments are:
% \begin{itemize}
%   \item \texttt{unresolved} (default): Prints unresolved conversations.
%   \item \texttt{all}: Prints both resolved and unresolved conversations.
%   \item \texttt{resolved}: Prints resolved conversations.
% \end{itemize}
%
% Here is a live demonstration of the summary report listing all conversations currently in this manual:
% \printconversations[all]
%
% \subsection{Elastic Overlap Prevention (Repulsion)}
%
% When multiple comment boxes are placed on consecutive or nearby lines, standard margin notes would overlap.
% The package prevents this by applying a 1D force-directed spring relaxation algorithm to shift overlapping comments.
% Adjacent comment boxes are shifted vertically relative to each other and bounded by the top and bottom page margins.
%
% The following example demonstrates the positioning of three comments on consecutive lines:
%
% First line: \bill{First comment}{Comment by Bill.}
% Second line: \vale{Second comment}{Comment by Vale.}
% Third line: \alice{Third comment}{Comment by Alice.}
%
% \StopEventually{\PrintChanges\PrintIndex}
%
% \section{Implementation}
%
% \iffalse
%<*package>
