\cs_new_protected:Nn \__comm_record:nnnn {
  \tl_set:Nn \l_comm_side_tl { R } % default
  \cs_if_exist:cT { commside #1 } {
    \tl_set:Nx \l_comm_side_tl { \use:c { commside #1 } }
  }
  
  \seq_if_exist:cF { g__comm_page_ids_seq_ #2 _ \l_comm_side_tl } {
    \seq_new:c { g__comm_page_ids_seq_ #2 _ \l_comm_side_tl }
    \seq_gput_right:Nx \g__comm_pages_seq { #2 _ \l_comm_side_tl }
  }
  \seq_gput_right:cn { g__comm_page_ids_seq_ #2 _ \l_comm_side_tl } { #1 }
  \prop_gput:Nnn \g__comm_src_y_prop { #1 } { #3 }
  \prop_gput:Nnn \g__comm_box_ht_prop { #1 } { #4 }
}

\NewDocumentCommand{\commrecord}{m m m m}{
  \__comm_record:nnnn { #1 } { #2 } { #3 } { #4 }
}

\cs_new_protected:Nn \__comm_solve_elasticity: {
  \dim_set:Nn \l_comm_top_margin_dim { \paperheight - 0.2in }
  \dim_set:Nn \l_comm_bottom_margin_dim { 0.2in }
  
  \seq_map_inline:Nn \g__comm_pages_seq {
    \group_begin:
    \bool_set_true:N \l_comm_valid_coords_bool
    
    % Check if all comments on this page-side have valid (non-zero) coordinates
    \seq_map_inline:cn { g__comm_page_ids_seq_ ##1 } {
      \dim_set:Nn \l_y_dim { \prop_item:Nn \g__comm_src_y_prop { ####1 } }
      \dim_compare:nNnT { \l_y_dim } = { 0pt } {
        \bool_set_false:N \l_comm_valid_coords_bool
      }
    }
    
    \bool_if:NT \l_comm_valid_coords_bool {
      % Initialize current Y positions to center-aligned unshifted positions
      \seq_map_inline:cn { g__comm_page_ids_seq_ ##1 } {
        \dim_set:Nn \l_y_orig { \prop_item:Nn \g__comm_src_y_prop { ####1 } }
        \dim_set:Nn \l_ht_dim { \prop_item:No \g__comm_box_ht_prop { ####1 } }
        \prop_put:Nox \l_curr_y_prop { ####1 } { \dim_eval:n { \l_y_orig + \ht\strutbox - \l_ht_dim / 2 } }
      }
      
      % Relaxation Loop (30 iterations)
      \int_step_inline:nnnn { 1 } { 1 } { 30 } {
        % Pairwise repulsion (only if page-side has > 1 comment)
        \int_compare:nT { \seq_count:c { g__comm_page_ids_seq_ ##1 } > 1 } {
          \int_step_inline:nnnn { 1 } { 1 } { \seq_count:c { g__comm_page_ids_seq_ ##1 } - 1 } {
            \tl_set:Nx \l_id_a { \seq_item:cn { g__comm_page_ids_seq_ ##1 } { ########1 } }
            \tl_set:Nx \l_id_b { \seq_item:cn { g__comm_page_ids_seq_ ##1 } { \int_eval:n { ########1 + 1 } } }
            
            \dim_set:Nn \l_y_a { \prop_item:No \l_curr_y_prop { \l_id_a } }
            \dim_set:Nn \l_y_b { \prop_item:No \l_curr_y_prop { \l_id_b } }
            
            \dim_set:Nn \l_ht_a { \prop_item:No \g__comm_box_ht_prop { \l_id_a } }
            \dim_set:Nn \l_ht_b { \prop_item:No \g__comm_box_ht_prop { \l_id_b } }
            
            \dim_set:Nn \l_min_dist { \l_ht_a / 2 + \l_ht_b / 2 + 3pt } % 3pt gap
            \dim_set:Nn \l_curr_dist { \l_y_a - \l_y_b }
            
            \dim_compare:nNnT { \l_curr_dist } < { \l_min_dist } {
              \dim_set:Nn \l_overlap { \l_min_dist - \l_curr_dist }
              \prop_put:Nox \l_curr_y_prop { \l_id_a } { \dim_eval:n { \l_y_a + \l_overlap / 2 } }
              \prop_put:Nox \l_curr_y_prop { \l_id_b } { \dim_eval:n { \l_y_b - \l_overlap / 2 } }
            }
          }
        }

        % Boundary constraints (if page-side has > 0 comments)
        \int_compare:nT { \seq_count:c { g__comm_page_ids_seq_ ##1 } > 0 } {
          % First comment (highest)
          \tl_set:Nx \l_id_first { \seq_item:cn { g__comm_page_ids_seq_ ##1 } { 1 } }
          \dim_set:Nn \l_y_dim { \prop_item:No \l_curr_y_prop { \l_id_first } }
          \dim_set:Nn \l_ht_dim { \prop_item:No \g__comm_box_ht_prop { \l_id_first } }
          \dim_compare:nNnT { \l_y_dim + \l_ht_dim / 2 } > { \l_comm_top_margin_dim } {
            \prop_put:Nox \l_curr_y_prop { \l_id_first } { \dim_eval:n { \l_comm_top_margin_dim - \l_ht_dim / 2 } }
          }
          
          % Last comment (lowest)
          \tl_set:Nx \l_id_last { \seq_item:cn { g__comm_page_ids_seq_ ##1 } { \seq_count:c { g__comm_page_ids_seq_ ##1 } } }
          \dim_set:Nn \l_y_dim { \prop_item:No \l_curr_y_prop { \l_id_last } }
          \dim_set:Nn \l_ht_dim { \prop_item:No \g__comm_box_ht_prop { \l_id_last } }
          \dim_compare:nNnT { \l_y_dim - \l_ht_dim / 2 } < { \l_comm_bottom_margin_dim } {
            \prop_put:Nox \l_curr_y_prop { \l_id_last } { \dim_eval:n { \l_comm_bottom_margin_dim + \l_ht_dim / 2 } }
          }
        }
      }
      
      % Save final calculated shifts
      \seq_map_inline:cn { g__comm_page_ids_seq_ ##1 } {
        \dim_set:Nn \l_y_orig { \prop_item:Nn \g__comm_src_y_prop { ####1 } }
        \dim_set:Nn \l_ht_dim { \prop_item:No \g__comm_box_ht_prop { ####1 } }
        \dim_set:Nn \l_y_final { \prop_item:Nn \l_curr_y_prop { ####1 } }
        \dim_set:Nn \l_shift { \l_y_orig + \ht\strutbox - \l_ht_dim / 2 - \l_y_final }
        \tl_gset:cx { g__comm_shift_ ####1 _dim } { \dim_use:N \l_shift }
      }
    }
    \group_end:
  }
}

\AtBeginDocument{
  \bool_if:NF \g_comm_final_bool {
    \__comm_solve_elasticity:
  }
}

% Helper to draw the marginal boxes
\cs_new_protected:Nn \__comm_draw_box:nn {
  \group_begin:
  \noindent % Ensure no indent in the margin
  \zlabel{commdest-#2}%
  \begin{tikzpicture}[remember~picture, baseline=(commdest-#2.center)]
    \node [
      draw=\l__comm_color_tl,
      fill=white,
      line~width=1.2pt,
      inner~sep=\fboxsep,
      text~width=\dimexpr \marginparwidth - 2\fboxsep - 1.2pt \relax,
      align=left,
      font=\scriptsize\raggedright,
      outer~sep=0pt
    ] (commdest-#2) {%
      \bool_set_true:N \l_comm_in_conversation_bool%
      \setlength{\parindent}{0pt}%
      \bool_if:NT \l_comm_resolved_bool {
        \textcolor{gray}{\textbf{[Resolved]}} \par\vspace{2pt}
      }
      \ignorespaces #1%
    };
  \end{tikzpicture}
  \group_end:
}
\cs_generate_variant:Nn \__comm_draw_box:nn { Vn }

% Render Note (shared positioning and line drawing logic)
\cs_new_protected:Nn \__comm_render_note:n {
  \bool_if:NTF \g_comm_final_bool {
    \tl_if_blank:nF { \l__comm_target_tl } {
      \l__comm_target_tl
    }
  }{
    \tl_set_eq:NN \l__comm_line_color_tl \l__comm_color_tl
    \int_gincr:N \g__comm_count_int
    \int_set_eq:NN \l__comm_id_int \g__comm_count_int
    
    % Marker
    \zsaveposy{commsrc-\int_use:N \l__comm_id_int}%
    \zlabel{commsrcpage-\int_use:N \l__comm_id_int}%
    \hypertarget{commsrc-\int_use:N \l__comm_id_int}{}%
    \tikz[remember~picture,overlay,baseline]{
      \node[anchor=base,inner~sep=0pt,outer~sep=0pt](commsrc-\int_use:N \l__comm_id_int){\strut};
    }

    % Measure box height of the comment
    \bool_set_eq:NN \l_comm_save_first_bool \l_comm_first_reply_bool
    \vbox_set:Nn \l_comm_scratch_box {
      \__comm_draw_box:Vn \l__comm_body_tl { \int_use:N \l__comm_id_int }
    }
    \bool_gset_eq:NN \l_comm_first_reply_bool \l_comm_save_first_bool
    \dim_set:Nn \l_comm_box_height_dim { \box_ht:N \l_comm_scratch_box + \box_dp:N \l_comm_scratch_box }

    % Detect position and write to aux (for next run)
    \begin{tikzpicture}[remember~picture, overlay]
    \path (commsrc-\int_use:N \l__comm_id_int.center); \pgfgetlastxy{\xn}{\yn}
    \path (current~page.center); \pgfgetlastxy{\xc}{\yc}
    \dim_compare:nNnTF { \xn } < { \xc } {
      \tl_set:Nn \l_tmpa_tl { L }
    }{
      \tl_set:Nn \l_tmpa_tl { R }
    }
    \iow_now:Nx \@auxout {
      \exp_not:N \expandafter \exp_not:N \gdef \exp_not:N \csname commside \int_use:N \l__comm_id_int \exp_not:N \endcsname { \l_tmpa_tl }
      \exp_not:N \commrecord { \int_use:N \l__comm_id_int } { \thepage } { \zposy{commsrc-\int_use:N \l__comm_id_int}sp } { \the\l_comm_box_height_dim }
      \exp_not:N \commreportentry { \int_use:N \l__comm_id_int } { \thepage } { \tl_to_str:N \l__comm_initiator_tl } { \tl_to_str:N \l__comm_initiator_color_tl } { \tl_to_str:N \l__comm_target_tl } { \exp_not:V \l__comm_snippet_tl } { \bool_if:NTF \l_comm_resolved_bool { true } { false } }
    }
  \end{tikzpicture}

  % Use the recorded side or default
  \cs_if_exist:cTF { commside \int_use:N \l__comm_id_int } {
    \str_if_eq:eeTF { \use:c { commside \int_use:N \l__comm_id_int } } { L } {
       \reversemarginpar
    }{
       \normalmarginpar
    }
  }{
    \normalmarginpar
  }

  % Fetch calculated elastic shift or default to 0pt
  \cs_if_exist:cTF { g__comm_shift_ \int_use:N \l__comm_id_int _dim } {
    \dim_set_eq:Nc \l_comm_shift_dim { g__comm_shift_ \int_use:N \l__comm_id_int _dim }
  }{
    \dim_set:Nn \l_comm_shift_dim { 0pt }
  }

  % Placement in margin with shift
  \use:x {
    \exp_not:N \marginnote 
      { \exp_not:N \__comm_draw_box:Vn \exp_not:N \l__comm_body_tl { \int_use:N \l__comm_id_int } } 
      [ \dim_eval:n { #1 + \l_comm_shift_dim } ]
  }
  
  \normalmarginpar % Reset

  \tl_if_blank:nF { \l__comm_target_tl } { 
    \group_begin:
    \color{\l__comm_line_color_tl} \l__comm_target_tl 
    \group_end:
  }

  % Draw the connecting line (only if both source and destination end up on the same page)
  \int_set:Nn \l_tmpa_int { \zref@extractdefault { commsrcpage-\int_use:N \l__comm_id_int } { abspage } { 0 } }
  \int_set:Nn \l_tmpb_int { \zref@extractdefault { commdest-\int_use:N \l__comm_id_int } { abspage } { 1 } }
  \int_compare:nNnT { \l_tmpa_int } = { \l_tmpb_int } {
    \use:x {
      \exp_not:N \begin{tikzpicture}[remember~picture,overlay]
        \exp_not:N \path (commsrc-\int_use:N \l__comm_id_int.center); \exp_not:N \pgfgetlastxy{\exp_not:N \commxsrc}{\exp_not:N \commysrc}
        \exp_not:N \path (commdest-\int_use:N \l__comm_id_int.center); \exp_not:N \pgfgetlastxy{\exp_not:N \commxdest}{\exp_not:N \commydest}
        \exp_not:N \ifdim \exp_not:N \commxdest > \exp_not:N \commxsrc
          \exp_not:N \draw[semithick, \l__comm_line_color_tl, opacity=0.8] 
            ($(current~page.center |- commsrc-\int_use:N \l__comm_id_int.base) + (0.5*\exp_not:N \textwidth, 0)$) 
            -- (commdest-\int_use:N \l__comm_id_int.west);
        \exp_not:N \else
          \exp_not:N \draw[semithick, \l__comm_line_color_tl, opacity=0.8] 
            ($(current~page.center |- commsrc-\int_use:N \l__comm_id_int.base) - (0.5*\exp_not:N \textwidth, 0)$) 
            -- (commdest-\int_use:N \l__comm_id_int.east);
        \exp_not:N \fi
      \exp_not:N \end{tikzpicture}
    }
  }
}
}

% Core alternating processing logic
\cs_generate_variant:Nn \prop_get:NnN { NoN }

\box_new:N \l_comm_scratch_box

% Public evaluation macro for a reply
\NewDocumentCommand{\commreply}{m m}{
  \bool_gset_false:N \g_comm_reply_handled_bool
  \group_begin:
    \bool_set_eq:NN \l_comm_save_first_bool \l_comm_first_reply_bool
    % Dry run in a scratch vbox to detect commentator macros
    \vbox_set:Nn \l_comm_scratch_box {
      \hsize=\dimexpr \marginparwidth - 2\fboxsep - 1.2pt \relax
      #2
    }
    \bool_gset_eq:NN \l_comm_first_reply_bool \l_comm_save_first_bool
  \group_end:
  
  \bool_if:NTF \g_comm_reply_handled_bool {
    % It was self-formatted: execute it directly in the main stream
    #2
  }{
    % Plain text: format with default author
    \use:c { #1 reply } { #2 }
  }
}

\cs_new_protected:Nn \__comm_process:nn {
  \bool_gset_true:N \l_comm_first_reply_bool
  
  \seq_get_left:NN \l__comm_args_seq \l_tmpa_tl
  \seq_pop_left:NN \l__comm_args_seq \l_tmpb_tl
  
  \tl_set_eq:NN \l__comm_target_tl \l_tmpa_tl

  \prop_clear:N \l_comm_replies_prop
  \seq_if_empty:NTF \l__comm_args_seq {
    \prop_put:Nnn \l_comm_replies_prop { 1/author } { #1 }
    \prop_put:Nox \l_comm_replies_prop { 1/body } { \l_tmpa_tl }
    \int_set:Nn \l_comm_replies_count { 1 }
    \tl_clear:N \l__comm_target_tl
  }{
    \prop_get:NnN \g_comm_commentators_prop { #1/partner } \l_initiator_partner_id_tl
    \int_set:Nn \l_comm_replies_count { \seq_count:N \l__comm_args_seq }
    
    \int_step_inline:nn { \l_comm_replies_count } {
      \int_if_odd:nTF { ##1 } { 
        \tl_set:Nn \l_curr_id_tl { #1 }
      }{ 
        \tl_set_eq:NN \l_curr_id_tl \l_initiator_partner_id_tl
        \tl_if_empty:NT \l_curr_id_tl {
          \tl_set:Nn \l_curr_id_tl { #1 }
        }
      }
      \prop_put:Nox \l_comm_replies_prop { ##1/author } { \l_curr_id_tl }
      \prop_put:Nox \l_comm_replies_prop { ##1/body } { \seq_item:Nn \l__comm_args_seq { ##1 } }
    }
  }

  % Replay/Build \l__comm_body_tl from property list with strict expansion protection
  \tl_clear:N \l__comm_body_tl
  \int_step_inline:nn { \l_comm_replies_count } {
    \prop_get:NnN \l_comm_replies_prop { ##1/author } \l_author_tl
    \prop_get:NnN \l_comm_replies_prop { ##1/body } \l_body_tl
    \tl_put_right:Nx \l__comm_body_tl { 
      \exp_not:N \commreply { \l_author_tl } { \exp_not:o \l_body_tl } 
    }
  }

  \prop_get:NnN \g_comm_commentators_prop { #1/name } \l__comm_initiator_tl
  \prop_get:NnN \g_comm_commentators_prop { #1/color } \l__comm_initiator_color_tl
  \tl_set:Nx \l__comm_snippet_tl {
    \seq_if_empty:NTF \l__comm_args_seq {
      \exp_not:N \commreply { #1 } { \exp_not:V \l__comm_body_tl }
    }{
      \exp_not:V \l__comm_body_tl
    }
  }

  \prop_get:NnN \g_comm_commentators_prop { #1/color } \l__comm_color_tl
  \__comm_render_note:n { #2 }
}

% Dynamic Commentator Registration
\cs_new_protected:Nn \__comm_register_commentator:nnnn {
  \prop_gput:Nnn \g_comm_commentators_prop { #1/name } { #2 }
  \prop_gput:Nnn \g_comm_commentators_prop { #1/color } { #3 }
  \prop_gput:Nnn \g_comm_commentators_prop { #1/partner } { #4 }

  % Main alternating command: \<id> (e.g. \bill)
  \exp_args:Nc \NewDocumentCommand { #1 } { s m +g +g +g +g +g +g O{0pt} } {%
    \bool_if:NTF \l_comm_in_conversation_bool {%
      % Inside a conversation: act as inline reply (format first argument)
      \use:c { #1 reply } { ##2 }%
    }{%
      % Thread starter
      \bool_if:NTF ##1 {
        \bool_set_true:N \l_comm_resolved_bool
      }{
        \bool_set_false:N \l_comm_resolved_bool
      }
      \seq_clear:N \l__comm_args_seq%
      \seq_put_right:Nn \l__comm_args_seq { ##2 }%
      \IfValueT { ##3 } { \seq_put_right:Nn \l__comm_args_seq { ##3 } }%
      \IfValueT { ##4 } { \seq_put_right:Nn \l__comm_args_seq { ##4 } }%
      \IfValueT { ##5 } { \seq_put_right:Nn \l__comm_args_seq { ##5 } }%
      \IfValueT { ##6 } { \seq_put_right:Nn \l__comm_args_seq { ##6 } }%
      \IfValueT { ##7 } { \seq_put_right:Nn \l__comm_args_seq { ##7 } }%
      \IfValueT { ##8 } { \seq_put_right:Nn \l__comm_args_seq { ##8 } }%
      \__comm_process:nn { #1 } { ##9 }%
    }%
  }

  % Inline formatter: \<id>reply (e.g. \billreply)
  \exp_args:Nc \NewDocumentCommand { #1 reply } { m } {%
    \bool_gset_true:N \g_comm_reply_handled_bool%
    \bool_if:NTF \l_comm_first_reply_bool {%
      \bool_gset_false:N \l_comm_first_reply_bool%
    }{%
      \par\vspace{3pt}%
    }%
    \textcolor { #3 } { \textbf { #2 : } ~ ##1 }%
  }
}

% Public registration API
\NewDocumentCommand{\newcommentator}{m m m O{}}{
  \__comm_register_commentator:nnnn { #1 } { #2 } { #3 } { #4 }
}

% Helper for adding report entries to the sequence
\cs_new_protected:Nn \__comm_add_report_entry:nnnnnnn {
  \seq_gput_right:Nn \g_comm_report_seq { { #1 } { #2 } { #3 } { #4 } { #5 } { #6 } { #7 } }
}

\NewDocumentCommand{\commreportentry}{m m m m m m m}{
  \__comm_add_report_entry:nnnnnnn { #1 } { #2 } { #3 } { #4 } { #5 } { #6 } { #7 }
}

% Multi-author explicit conversation command
\NewDocumentCommand{\conversation}{s m +m O{0pt}}{
  \group_begin:
  \bool_if:NTF #1 {
    \bool_set_true:N \l_comm_resolved_bool
  }{
    \bool_set_false:N \l_comm_resolved_bool
  }
  \bool_gset_true:N \l_comm_first_reply_bool
  \tl_set:Nn \l__comm_target_tl { #2 }
  \tl_set:Nn \l__comm_body_tl { #3 }
  \tl_trim_spaces:N \l__comm_body_tl
  \tl_set:Nn \l__comm_color_tl { gray } % Neutral rim for multi-author
  \tl_set:Nn \l__comm_initiator_tl { Group }
  \tl_set:Nn \l__comm_initiator_color_tl { gray }
  \tl_set_eq:NN \l__comm_snippet_tl \l__comm_body_tl
  \__comm_render_note:n { #4 }
  \group_end:
}

% Fallbacks for hyperref if not loaded
\providecommand{\hypertarget}[2]{#2}
\providecommand{\hyperlink}[2]{#2}

% Helper for rendering report entries
\cs_new_protected:Nn \__comm_render_report_entry:nnnnnnnn {
  \group_begin:
  \tl_set:Nn \l_curr_filter_tl { #8 }
  \bool_set_true:N \l_comm_should_print_bool
  
  \str_if_eq:VnT \l_curr_filter_tl { unresolved } {
    \str_if_eq:eeT { #7 } { true } {
      \bool_set_false:N \l_comm_should_print_bool
    }
  }
  \str_if_eq:VnT \l_curr_filter_tl { resolved } {
    \str_if_eq:eeT { #7 } { false } {
      \bool_set_false:N \l_comm_should_print_bool
    }
  }
  
  \bool_if:NT \l_comm_should_print_bool {
    \vspace{8pt}
    \noindent
    \hyperlink{commsrc-#1}{\textbf{[\##1]}}~on~page~\hyperlink{commsrc-#1}{#2}~~---~~%
    \str_if_eq:eeTF { #7 } { true } {
      \textcolor{gray}{\textbf{[Resolved]}}
    }{
      \textcolor{red}{\textbf{[Unresolved]}}
    }
    \par\vspace{3pt}
    \tl_if_blank:nF { #5 } {
      \hspace*{1.5em}\textbf{Target:}~\texttt{\tl_to_str:n { #5 }} \par\vspace{2pt}
    }
    \hspace*{1.5em}\textbf{Initiator:}~\textcolor{#4}{\textbf{#3}} \par\vspace{2pt}
    \hspace*{1.5em}\textbf{Comments:}~#6
    \par
  }
  \group_end:
}

% Public API to print report
\NewDocumentCommand{\printconversations}{O{unresolved}}{
  \group_begin:
  \bool_set_true:N \l_comm_in_conversation_bool
  \seq_if_empty:NTF \g_comm_report_seq {
    No~conversations~recorded.
  }{
    \seq_map_inline:Nn \g_comm_report_seq {
      \__comm_render_report_entry:nnnnnnnn ##1 { #1 }
    }
  }
  \group_end:
}

