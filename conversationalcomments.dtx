% Review Margin Configuration
\newlength{\reviewmarginwidth}

\cs_new_protected:Nn \__comm_set_review_margin_width:n {
  \bool_if:NF \g_comm_final_bool {
    \setlength{\reviewmarginwidth}{#1}
    \geometry{
        paperwidth=\dimexpr \g__comm_orig_paperwidth_dim + 2\reviewmarginwidth \relax,
        paperheight=\g__comm_orig_paperheight_dim,
        textwidth=\g__comm_orig_textwidth_dim,
        textheight=\g__comm_orig_textheight_dim,
        marginparwidth=\reviewmarginwidth,
        marginparsep=0.15in,
        hcentering,
        vcentering
    }
  }
}

